# =============================================================================
# AI News Aggregator — Environment Variables
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in real values (never commit .env to git)
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (must match docker/docker-compose.yml values)
# -----------------------------------------------------------------------------
POSTGRES_DB=ai_news
POSTGRES_USER=ai_news_user
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Assembled by app/database/session.py — you can override it directly instead.
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://ai_news_user:changeme_in_production@localhost:5432/ai_news

# -----------------------------------------------------------------------------
# pgAdmin (optional web UI — only used by docker-compose)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# OpenAI API key — used by digest/curator agents
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Gmail — used by the email agent to send digests
# Steps to get an App Password:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to myaccount.google.com/apppasswords
#   3. Generate a password for "Mail".
# -----------------------------------------------------------------------------
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# -----------------------------------------------------------------------------
# Residential proxy — optional, helps avoid YouTube / Anthropic rate limits.
# Format: http://username:password@host:port
# Leave blank to run without a proxy (may get blocked on heavy usage).
# -----------------------------------------------------------------------------
RESIDENTIAL_PROXY_URL=

# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
# How many hours back to look for new content (default 6 days)
HOURS_LOOKBACK=144

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
